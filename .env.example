# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Application (client) ID, found on the same "General Information" page as the token
CLIENT_ID=

# Optional: set this to a single guild ID while developing so slash commands
# register instantly (guild commands update immediately; global commands can
# take up to an hour to propagate). Leave blank to register globally.
#
# Also used as the default server for the local control API (see below) so
# the desktop hotkey/overlay app knows which server to play sounds in.
GUILD_ID=

# --- Local control API (used by the desktop hotkey/overlay app) ---

# Required to enable the API. Generate any random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# The desktop app must send this same value in the x-api-key header.
API_KEY=

# Port the control API listens on.
API_PORT=3939

# Host/interface to bind to. Use 127.0.0.1 to only allow the API to be
# reached from this same machine; use 0.0.0.0 to allow other devices on
# your network (e.g. a friend's PC) to control the bot too.
API_HOST=127.0.0.1

# Default voice channel the bot joins when /play or the control API is
# used without specifying a channel explicitly. Right-click a voice
# channel in Discord (Developer Mode required) and "Copy Channel ID".
VOICE_CHANNEL_ID=
